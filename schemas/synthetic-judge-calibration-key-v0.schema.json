{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/huangfanwei25-lang/accountable-dialogue/blob/main/schemas/synthetic-judge-calibration-key-v0.schema.json",
  "title": "Synthetic Judge Calibration Key v0",
  "description": "Precommitted expected verdict vectors for fully synthetic judge calibration. This file is never rendered into a judge prompt.",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "key_id", "public_summary", "allowed_verdicts", "case_expectations", "known_limitations"],
  "properties": {
    "format": {"const": "accountable-dialogue/synthetic-judge-calibration-key-v0"},
    "key_id": {"$ref": "#/$defs/id"},
    "public_summary": {"$ref": "#/$defs/text"},
    "allowed_verdicts": {"type": "array", "minItems": 4, "uniqueItems": true, "items": {"$ref": "#/$defs/verdict"}},
    "case_expectations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/case_expectation"}},
    "known_limitations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
    "label_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
    "text": {"type": "string", "minLength": 1, "maxLength": 2000},
    "verdict": {"enum": ["pass", "fail", "not_applicable", "unrateable"]},
    "expected_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label_id", "verdict", "required_response_field_refs", "required_material_refs"],
      "properties": {
        "label_id": {"$ref": "#/$defs/label_id"},
        "verdict": {"$ref": "#/$defs/verdict"},
        "required_response_field_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["conclusion", "evidence_refs", "prior_claim_ref", "unknown_or_correction", "authority_next_step"]}},
        "required_material_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
      }
    },
    "case_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "case_sha256", "expected_verdicts"],
      "properties": {
        "case_id": {"$ref": "#/$defs/id"},
        "case_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "expected_verdicts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/expected_verdict"}}
      }
    }
  }
}
