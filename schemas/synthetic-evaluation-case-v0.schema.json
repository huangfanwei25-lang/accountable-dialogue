{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/huangfanwei25-lang/accountable-dialogue/blob/main/schemas/synthetic-evaluation-case-v0.schema.json",
  "title": "Accountable Dialogue Synthetic Evaluation Case v0",
  "description": "A public, fictional, low-risk input fixture for an exploratory B0/I1 comparison. It contains no model output or result.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "case_id",
    "public_summary",
    "family",
    "risk",
    "task",
    "materials",
    "structured_context",
    "response_contract",
    "annotation_key",
    "known_limitations"
  ],
  "properties": {
    "format": {
      "const": "accountable-dialogue/synthetic-evaluation-case-v0"
    },
    "case_id": {
      "$ref": "#/$defs/id"
    },
    "public_summary": {
      "$ref": "#/$defs/text"
    },
    "family": {
      "enum": ["h1", "h2", "h3", "h4a"]
    },
    "risk": {
      "$ref": "#/$defs/risk"
    },
    "task": {
      "$ref": "#/$defs/text"
    },
    "materials": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/material"
      }
    },
    "structured_context": {
      "$ref": "#/$defs/structured_context"
    },
    "response_contract": {
      "$ref": "#/$defs/response_contract"
    },
    "annotation_key": {
      "$ref": "#/$defs/annotation_key"
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/text"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "reversible"],
      "properties": {
        "class": {
          "const": "low"
        },
        "reversible": {
          "const": true
        }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "text"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "enum": [
            "source_excerpt",
            "claim",
            "test_result",
            "event",
            "policy",
            "authority_constraint",
            "role_statement",
            "audit_record"
          ]
        },
        "text": {
          "$ref": "#/$defs/text"
        }
      }
    },
    "evidence_link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_ref", "source_ref", "relation"],
      "properties": {
        "subject_ref": {
          "$ref": "#/$defs/id"
        },
        "source_ref": {
          "$ref": "#/$defs/id"
        },
        "relation": {
          "enum": ["supports", "challenges", "limits", "records"]
        }
      }
    },
    "structured_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_refs", "evidence_links", "event_refs", "authority_material_refs"],
      "properties": {
        "subject_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "evidence_links": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_link"
          }
        },
        "event_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "authority_material_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "response_contract": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {"const": "conclusion"},
        {"const": "evidence_refs"},
        {"const": "prior_claim_ref"},
        {"const": "unknown_or_correction"},
        {"const": "authority_next_step"}
      ],
      "items": false
    },
    "annotation_key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "locator", "sha256"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "locator": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[a-zA-Z0-9._/-]+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
