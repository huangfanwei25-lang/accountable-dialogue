{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/huangfanwei25-lang/accountable-dialogue/blob/main/schemas/blind-semantic-annotation-packet-v0.schema.json",
  "title": "Accountable Dialogue Blind Semantic Annotation Packet v0",
  "description": "A condition-blind, fully synthetic packet for a future independent semantic annotation. It is not a model prompt, rating, result, or mapping.",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "packet_id", "case_id", "blind_alias", "shared_task", "shared_materials", "response", "rubric", "rubric_sha256", "mechanical_status", "known_limitations"],
  "properties": {
    "format": {"const": "accountable-dialogue/blind-semantic-annotation-packet-v0"},
    "packet_id": {"$ref": "#/$defs/id"},
    "case_id": {"$ref": "#/$defs/id"},
    "blind_alias": {"enum": ["A", "B"]},
    "shared_task": {"$ref": "#/$defs/text"},
    "shared_materials": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/material"}
    },
    "response": {"$ref": "#/$defs/response"},
    "rubric": {"$ref": "#/$defs/rubric"},
    "rubric_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "mechanical_status": {"const": "valid"},
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/text"}
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
    "label_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{2,63}$"},
    "text": {"type": "string", "minLength": 1, "maxLength": 2000},
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "text"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"type": "string", "minLength": 1, "maxLength": 2000},
        "text": {"$ref": "#/$defs/text"}
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conclusion", "evidence_refs", "prior_claim_ref", "unknown_or_correction", "authority_next_step"],
      "properties": {
        "conclusion": {"$ref": "#/$defs/text"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
        "prior_claim_ref": {"$ref": "#/$defs/text"},
        "unknown_or_correction": {"$ref": "#/$defs/text"},
        "authority_next_step": {"$ref": "#/$defs/text"}
      }
    },
    "rubric_label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "pass_when", "fail_when"],
      "properties": {
        "id": {"$ref": "#/$defs/label_id"},
        "pass_when": {"$ref": "#/$defs/text"},
        "fail_when": {"$ref": "#/$defs/text"}
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "labels", "allowed_verdicts"],
      "properties": {
        "key_id": {"$ref": "#/$defs/id"},
        "labels": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/rubric_label"}},
        "allowed_verdicts": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 4,
          "maxItems": 4,
          "items": {"enum": ["pass", "fail", "not_applicable", "unrateable"]}
        }
      }
    }
  }
}
